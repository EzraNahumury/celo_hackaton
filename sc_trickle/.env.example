# ─────────────────────────────────────────────────────────────
#  TrickleVault – Environment Variables
#  Copy this file to .env and fill in the real values.
#  NEVER commit .env – it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# Deployer wallet private key (with or without 0x prefix)
# Fund this address with test CELO: https://faucet.celo.org
PRIVATE_KEY=your_private_key_here

# Celoscan API key – used for contract verification
# Get one free at: https://celoscan.io/myapikey
CELOSCAN_API_KEY=your_celoscan_api_key_here

# ── Token Addresses on Celo Sepolia (chain 11142220) ───────────
# USDC – primary token for payroll streams
TOKEN_USDC=0x01C5C0122039549AD1493B8220cABEdD739BC44E

# USDm (Mento Dollar) – Celo-native USD alternative
TOKEN_USDm=0xEF4d55D6dE8e8d73232827Cd1e9b2F2dBb45bC80

# EURm – for EUR-denominated payroll
TOKEN_EURm=0x6B172e333e2978484261D7eCC3DE491E79764BbC
