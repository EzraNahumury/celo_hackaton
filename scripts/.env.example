# Hot wallet private key (must hold CELO for gas + the token you spam)
PRIVATE_KEY=0x...

# TrickleVault — defaults below are Celo Mainnet (chain 42220)
VAULT_ADDRESS=0x8a3e5d16F088A1D96f554970e5eED8468e7ddc05

# Token used for spam cycles (USDC on Celo Mainnet)
TOKEN_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
TOKEN_DECIMALS=6

# Seconds between tx bursts. 30–60s keeps the leaderboard busy without melting gas.
INTERVAL_SECONDS=45

# Tiny amount spammed per cycle (in token units, not wei)
AMOUNT=0.01

# -- Sepolia preset (uncomment to target testnet instead) ---------------------
# VAULT_ADDRESS=0x42cADdd47E795A6e04d820A6c140AF04159C7542
# TOKEN_ADDRESS=0x01C5C0122039549AD1493B8220cABEdD739BC44E
